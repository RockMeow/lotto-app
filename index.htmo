<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>數學魔法遊樂場</title>
    <style>
        body { font-family: sans-serif; text-align: center; background: #fff0f5; }
        .box { background: white; padding: 20px; border-radius: 20px; margin: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .dot { display: inline-block; width: 30px; height: 30px; background: #ff7675; border-radius: 50%; margin: 5px; }
        button { font-size: 20px; padding: 10px 20px; cursor: pointer; }
    </style>
</head>
<body>

    <div class="box">
        <h2>視覺加法：數字積木</h2>
        <div id="visual-sum"></div>
        <p id="sum-text">3 + 2 = ?</p>
        <button onclick="playSum()">換個題目</button>
    </div>

    <div class="box">
        <h2>乘法跳躍：青蛙找荷葉</h2>
        <div id="jump-game"></div>
        <p id="jump-text">3 x 4 = ?</p>
        <button onclick="playJump()">換個題目</button>
    </div>

<script>
    // 加法練習：用圓點模擬數字
    function playSum() {
        let a = Math.floor(Math.random() * 5) + 1;
        let b = Math.floor(Math.random() * 5) + 1;
        let container = document.getElementById('visual-sum');
        container.innerHTML = "";
        for(let i=0; i<a+b; i++) {
            let dot = document.createElement('div');
            dot.className = 'dot';
            container.appendChild(dot);
        }
        document.getElementById('sum-text').innerText = `${a} + ${b} = ${a+b}`;
    }

    // 乘法跳躍：用文字呈現跳躍過程
    function playJump() {
        let a = Math.floor(Math.random() * 4) + 2; // 每跳 a 格
        let b = Math.floor(Math.random() * 4) + 2; // 跳 b 次
        let result = a * b;
        let steps = [];
        for(let i=1; i<=b; i++) steps.push(i*a);
        document.getElementById('jump-text').innerText = 
            `${a} x ${b} = 跳跳看：${steps.join(' -> ')} = ${result}`;
    }

    playSum(); playJump();
</script>
</body>
</html>
